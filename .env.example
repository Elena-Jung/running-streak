# ── Discord ───────────────────────────────────────────────
# 봇 토큰 (Developer Portal → Bot → Reset Token). 절대 공유/커밋 금지.
DISCORD_TOKEN=여기에_봇_토큰
# 서버(길드) ID — 개발자 모드 켜고 서버 우클릭 → ID 복사.
DISCORD_GUILD_ID=000000000000000000
# 자동 집계 대상 채널 ID — 채널 우클릭 → ID 복사.
TARGET_CHANNEL_ID=000000000000000000

# ── PostgreSQL (봇 전용 컨테이너, 호스트 미발행) ───────────
POSTGRES_USER=streak
POSTGRES_PASSWORD=여기에_강한_무작위_비밀번호
POSTGRES_DB=streak
# 컨테이너 내부 접속 정보(보통 그대로 둠). compose 가 bot 에 주입하지만 명시 가능.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── 기타 ──────────────────────────────────────────────────
TZ=Asia/Seoul
# OCR(거리 부가정보) on/off. 실패해도 스트릭엔 영향 없음.
OCR_ENABLED=true
# 킬스위치/유지보수 모드. true 면 사진 업로드 집계를 즉시 중단(조회 커맨드는 동작).
# 잘못된 집계를 급히 멈출 때: .env 에서 true 로 바꾸고 `docker compose up -d bot`.
BOT_PAUSED=false
# 마일스톤 "자랑 카드"(/자랑) 정적 페이지 주소. web/ 폴더를 정적 호스트로 서빙한 뒤 그 주소를 적는다.
# 예: https://run.example.org  · 비워 두면 /자랑 은 링크 대신 통계를 텍스트로만 보여준다.
BRAG_BASE_URL=
